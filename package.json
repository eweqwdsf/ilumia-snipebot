{
  "name": "ilumia-snipebot",
  "version": "1.9.0",
  "description": "ILUMIA SnipeBot Launcher",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "dependencies": {
    "dotenv": "^16.4.5"
  },
  "build": {
    "appId": "com.ilumia.snipebot",
    "productName": "ILUMIA",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "executableName": "ILUMIA",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": false,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "shortcutName": "ILUMIA",
      "deleteAppDataOnUninstall": false,
      "artifactName": "ILUMIA-Setup.exe"
    },
    "extraResources": [
      {
        "from": "python/dist/bridge.exe",
        "to": "python/bridge.exe"
      },
      {
        "from": "python/dist/main_bot.exe",
        "to": "python/main_bot.exe"
      },
      {
        "from": "assets/",
        "to": "assets/",
        "filter": ["**/*"]
      },
      {
        "from": "python/.env",
        "to": "python/.env"
      },
      {
        "from": "chromium",
        "to": "chromium"
      }
    ],
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ]
  },
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1"
  }
}